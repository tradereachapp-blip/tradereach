# =============================================================================
# TradeReach Environment Variables
# Copy this file to .env.local and fill in all values before running
# =============================================================================

# --- Supabase ---
# Found in: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe ---
# Found in: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret from: Stripe Dashboard > Developers > Webhooks > signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in Stripe Dashboard > Products
# Pro: $397/month with 7-day trial
STRIPE_PRO_PRICE_ID=price_...
# Elite: $697/month with 7-day trial
STRIPE_ELITE_PRICE_ID=price_...
# Pay-per-lead overage for Pro (over 20 lead cap): $30/lead
STRIPE_PRO_OVERAGE_PRICE_ID=price_...
# Team member seat: $49/month per additional user
STRIPE_TEAM_MEMBER_PRICE_ID=price_...

# --- Resend (Email) ---
# Found in: resend.com > API Keys
RESEND_API_KEY=re_...
# The from-address for all emails (must be verified domain)
RESEND_FROM_EMAIL=noreply@tradereachapp.com
# Admin email for system alerts
ADMIN_EMAIL=admin@tradereachapp.com

# --- Twilio (SMS) ---
# Found in: twilio.com > Console
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Your Twilio phone number (E.164 format)
TWILIO_PHONE_NUMBER=+1...

# --- App ---
# Production URL — must match Supabase Site URL and Stripe redirect URLs
NEXT_PUBLIC_APP_URL=https://tradereachapp.com

# --- Support Phone (homeowner-facing) ---
# Displayed on homeowner confirmation pages and emails. Leave blank to hide.
# Use E.164 format for tel: links, e.g. +15551234567
NEXT_PUBLIC_SUPPORT_PHONE=
SUPPORT_PHONE=

# --- Admin Panel ---
# Secret password to access /admin panel
ADMIN_PASSWORD=change-this-to-a-strong-secret

# --- Vercel Cron Security ---
# Random secret to authenticate cron job calls — generate with: openssl rand -hex 32
CRON_SECRET=change-this-to-a-random-string

# --- Anthropic (Claude AI for Rex chatbot) ---
# Get key from: https://console.anthropic.com
# Make sure billing is enabled on your Anthropic account
ANTHROPIC_API_KEY=sk-ant-...

# --- Chat Encryption ---
# Random 32-char hex string — NEVER expose this publicly
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
CHAT_ENCRYPTION_KEY=your-32-char-hex-string-here

# --- Monitoring Alerts ---
# Your personal cell in E.164 format — receives SMS on service outages
MONITORING_ALERT_PHONE=+1...
